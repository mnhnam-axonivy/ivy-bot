      "connect" : [
        { "id" : "f18", "to" : "f1", "color" : "default" }
      ]
    }, {
      "id" : "f20",
      "type" : "Script",
      "name" : "Add agent message",
      "config" : {
        "output" : {
          "code" : [
            "in.answer.setRole(\"AI\");",
            "in.messages.add(in.answer);"
          ]
        }
