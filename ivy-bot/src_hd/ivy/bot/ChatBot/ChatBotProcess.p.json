    }, {
      "id" : "f26",
      "type" : "Alternative",
      "name" : "Has history?",
      "config" : {
        "conditions" : {
          "f27" : "!in.messages.isEmpty()"
        }
      },
      "visual" : {
        "at" : { "x" : 176, "y" : 256 },
        "labelOffset" : { "y" : -16 }
      },
      "connect" : [
        { "id" : "f27", "to" : "f24" },
        { "id" : "f28", "to" : "f5", "via" : [ { "x" : 176, "y" : 336 }, { "x" : 472, "y" : 336 } ] }
      ]
    }, {
      "id" : "f24",
      "type" : "Script",
      "name" : "Build past conversation",
      "config" : {
        "output" : {
          "code" : [
            "import entity.Message;",
            "",
            "StringBuilder sb = new StringBuilder();",
            "for (Message msg : in.messages) {",
            "    if (sb.length() > 0) {",
            "        sb.append(\"\\n\");",
            "    }",
            "    sb.append(msg.getRole()).append(\": \").append(msg.getContent());",
            "}",
            "in.pastConversation = sb.toString();",
            "",
            "ivy.log.error(in.pastConversation);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 304, "y" : 256 },
        "size" : { "width" : 128, "height" : 62 }
      },
      "connect" : [
        { "id" : "f25", "to" : "f5" }
      ]
    }, {
      "id" : "f5",
      "type" : "Script",
      "name" : "Add user message",
      "config" : {
        "output" : {
          "code" : [
            "import entity.Message;",
            "",
            "Message msg = new Message();",
            "msg.setRole(\"USER\");",
            "msg.setContent(in.message);",
            "",
            "in.messages.add(msg);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 480, "y" : 256 }
      },
      "connect" : [
        { "id" : "f14", "to" : "f6" }
      ]
    }, {
      "id" : "f6",
      "type" : "SubProcessCall",
      "name" : "Chat Agent",
      "config" : {
        "processCall" : "ivy/bot/agent/ChatAgent:chat(String,String)",
        "call" : {
          "map" : {
            "param.query" : "in.message",
            "param.pastConversation" : "in.pastConversation"
          }
        },
        "output" : {
          "map" : {
            "out" : "in",
            "out.answer" : "result.answer"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 656, "y" : 256 },
        "size" : { "width" : 128 }
      },
      "connect" : [
        { "id" : "f19", "to" : "f20" }
      ]
    }, {
      "id" : "f8",
      "type" : "HtmlDialogEnd",
      "visual" : {
        "at" : { "x" : 1160, "y" : 256 }
      }
    }, {
      "id" : "f17",
      "type" : "Script",
      "name" : "Init message list",
      "config" : {
        "output" : {
          "code" : [
            "import java.util.ArrayList;",
            "",
            "in.messages = new ArrayList();"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 224, "y" : 64 }
