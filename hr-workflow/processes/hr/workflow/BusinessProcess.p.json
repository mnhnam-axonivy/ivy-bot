      "config" : {
        "output" : {
          "code" : [
            "import hr.workflow.LeaveRequest;",
            "in.request = new LeaveRequest();",
            "in.request.setStatus(\"PENDING\");",
            "in.request.setEmployeeName(in.username);",
            "if (in.leaveType != null) { in.request.setLeaveType(in.leaveType); }",
            "if (in.startDate != null) { in.request.setStartDate(in.startDate); }",
            "if (in.endDate != null) { in.request.setEndDate(in.endDate); }",
            "if (in.reason != null) { in.request.setReason(in.reason); }"
          ]
        }
      },
