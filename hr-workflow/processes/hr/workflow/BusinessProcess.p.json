            { "name" : "endDate", "type" : "java.time.LocalDate", "desc" : "Last day of leave" },
            { "name" : "reason", "type" : "String", "desc" : "Reason for the leave request" },
            { "name" : "username", "type" : "String", "desc" : "Username of the employee initiating the leave request" }
          ],
          "map" : {
            "out.leaveType" : "param.leaveType",
            "out.startDate" : "param.startDate",
            "out.endDate" : "param.endDate",
            "out.reason" : "param.reason",
            "out.username" : "param.username"
          }
        },
        "request" : {
          "name" : "Leave Request",
          "description" : "Submit a new leave request",
